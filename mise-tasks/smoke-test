#!/usr/bin/env bash
#MISE description="Run plugin tests - install and verify Zephyr SDK toolchain"
#USAGE arg "[sdk_version]" help="Zephyr SDK version to test with" default="0.17.4" env="ZEPHYR_SDK_TEST_VERSION"
set -euo pipefail

# Verify arm-zephyr-eabi-gcc is available via the toolchain
output1=$(mise x "zephyr-sdk:zephyr-sdk@${usage_sdk_version?}" -- arm-zephyr-eabi-gcc --version 2>&1 || true)
echo "arm-zephyr-eabi-gcc output: $output1"
if echo "$output1" | grep -qi 'gcc'; then
    echo "Arm Zephyr Toolchain Tests passed"
else
    echo "Test failed: arm-zephyr-eabi-gcc not found or not working"
    exit 1
fi
output2=$(mise x "zephyr-sdk:zephyr-sdk@${usage_sdk_version?}" -- x86_64-zephyr-elf-gcc --version 2>&1 || true)
echo "x86_64-zephyr-elf-gcc output: $output2"
if echo "$output2" | grep -qi 'gcc'; then
    echo "Host Tools Tests passed"
else
    echo "Test failed: x86_64-zephyr-elf-gcc not found or not working"
    exit 1
fi
