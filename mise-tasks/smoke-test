#!/usr/bin/env zsh
#MISE description="Smoke test all tools for a backend version"
#USAGE arg "<backend>" help="Backend name"
set -euo pipefail

BACKEND="${usage_backend:?}"
tools=(${(f)"$(<tests/tools.txt)"})
print "Testing backend ${BACKEND:?}:"
print -rl "${tools[@]}"

mise plugins link "${BACKEND}" "${MISE_CONFIG_ROOT:?}" --force

for tool in "${tools[@]}"; do
  arr=("${(s.:.)tool}")
  name="${arr[1]}"
  version="${arr[2]}"
  cmd=(${arr[3]})
  print -R "--- ${name}@${version} ---"

  print "Testing version listing..."
  mise ls-remote "${BACKEND}:${name}"

  print "Executing: ${cmd[@]}"
  mise x "${BACKEND}:${name}@${version}" -- ${=cmd[@]}

done
