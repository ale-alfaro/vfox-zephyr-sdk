#!/usr/bin/env zsh
#MISE description="Integration test - build a sample with the selected toolchain + west"
#MISE hide=true
#MISE dir="{{cwd}}"
#USAGE arg "<toolchain>" help="Toolchain to test"
#USAGE arg "<west>" help="West tool to test"
set -euo pipefail
TOOLCHAIN_TOOL="${usage_toolchain?}"
WEST_TOOL="${usage_west?}"

: "${BACKEND:?BACKEND must be set}"
: "${BOARD:?BOARD must be set board}"
: "${SAMPLE:?SAMPLE must be set}"
echo "TOOLCHAIN_TOOL=${TOOLCHAIN_TOOL}"
echo "WEST_TOOL=${WEST_TOOL}"
echo "BACKEND=${BACKEND}"
echo "BOARD=${BOARD}"
echo "SAMPLE=${SAMPLE}"

# ── West init & update ─────────────────────────────────────────────
_west=(mise x "${WEST_TOOL}" '--' west)
_west_build=(mise x "${WEST_TOOL}" "${TOOLCHAIN_TOOL}" '--' west build)
$_west init -l app
$_west update -o=--depth=1 --narrow --auto-cache ~/.cache/west
$_west_build -p -b "${BOARD}" "${SAMPLE}" -d build

# ── Verify output ──────────────────────────────────────────────────
if [[ -d build ]]; then
  echo "Integration test: build succeeded"
else
  echo "Integration test: build directory not found"
  exit 1
fi
