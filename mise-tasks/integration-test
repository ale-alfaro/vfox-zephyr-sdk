#!/usr/bin/env bash
#MISE description="Integration test - build a Zephyr sample with the Zephyr SDK"
#MISE hide=true
#MISE env={MISE_VERBOSE=1}
#USAGE arg "<dir>" help="Workspace directory"
#USAGE arg "<version>" help="Zephyr SDK version to test with" env="BACKEND_TEST_VERSION"

set -euo pipefail
WORKSPACE="${usage_dir:?}"
BACKEND_VERSION="${usage_version:?}"
declare -A ZEPHYR_COMPATIBLITY
ZEPHYR_COMPATIBLITY=(
  ["v1.0.0"]="v4.4.0"
  ["v0.17.4"]="v4.3.0"
  ["v0.17.3"]="v4.2.0"
  ["v0.17.2"]="v4.1.0"
  ["v0.17.1"]="v4.0.0"
  ["v0.17.0"]="v4.0.0"
)
echo "WORKSPACE=${WORKSPACE} BACKEND_VERSION=$BACKEND_VERSION"
pushd "${WORKSPACE}"
APPDIR="${WORKSPACE?}/app"
cleanup() {
  echo "Cleanup!"
  mise uninstall "zephyr-sdk-test:west@${BACKEND_VERSION}" 2>/dev/null || true
  mise uninstall "zephyr-sdk-test:arm-zephyr-eabi@${BACKEND_VERSION}" 2>/dev/null || true
  mise uninstall "zephyr-sdk-test:minimal@${BACKEND_VERSION}" 2>/dev/null || true
  rm -rf "$WORKSPACE"
}
trap cleanup EXIT

version_v="v${BACKEND_VERSION}"
ZEPHYR_VERSION="${ZEPHYR_COMPATIBLITY[$version_v]}"
echo "creating workspace with zephyr version ${ZEPHYR_VERSION}"
# ── Write minimal west manifest ────────────────────────────────────
mkdir "${APPDIR?}"
cat >"${APPDIR}/west.yml" <<YAML
manifest:
  remotes:
    - name: zephyrproject-rtos
      url-base: https://github.com/zephyrproject-rtos
  projects:
    - name: zephyr
      remote: zephyrproject-rtos
      revision: ${ZEPHYR_VERSION?}
      clone-depth: 1
      import:
        name-allowlist:
          - cmsis

  self:
    path: app
YAML

# ── West init & update ─────────────────────────────────────────────
pushd "${APPDIR}"
mise x "zephyr-sdk-test:west@${BACKEND_VERSION}" -- west init -l .
WEST_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/vfox-zephyr-sdk-test"
mkdir -p "${WEST_CACHE}"
mise x "zephyr-sdk-test:west@${BACKEND_VERSION}" -- west update --narrow --auto-cache "${WEST_CACHE}"
mise set ZEPHYR_BASE="$WORKSPACE/zephyr"
mise x "zephyr-sdk-test:west@${BACKEND_VERSION}" -- west build -p -b native_sim -s "$WORKSPACE/zephyr/samples/hello_world" -d build

# ── Verify output ──────────────────────────────────────────────────
if [[ -d build && -e build/zephyr/zephyr.exe ]]; then
  echo "Integration test passed: zephyr.elf built successfully"
else
  echo "Integration test failed: build/zephyr/zephyr.elf not found"
  exit 1
fi
popd
