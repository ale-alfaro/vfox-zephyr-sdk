#!/usr/bin/env bash
#MISE description="Integration test - build a Zephyr sample with the Zephyr SDK"
#MISE hide=true
set -euo pipefail

: "${BACKEND:?Set BACKEND env var}"
: "${BACKEND_VERSION:?Set BACKEND_VERSION env var}"

fail() {
  echo "⚠ FAIL: $*"
  exit 1
}
pass() { echo "✓ PASS: $*"; }

WORKSPACE="$(mktemp -d)"
declare -A ZEPHYR_COMPAT
ZEPHYR_COMPAT=(
  ["v1.0.0"]="v4.4.0"
  ["v0.17.4"]="v4.3.0"
  ["v0.17.0"]="v4.0.0"
)

cleanup() {
  echo "Cleaning up..."
  mise uninstall "${BACKEND}:west@${BACKEND_VERSION}" 2>/dev/null || true
  mise uninstall "${BACKEND}:arm-zephyr-eabi@${BACKEND_VERSION}" 2>/dev/null || true
  mise uninstall "${BACKEND}:minimal@${BACKEND_VERSION}" 2>/dev/null || true
  rm -rf "$WORKSPACE"
}
trap cleanup EXIT

ZEPHYR_VERSION="${ZEPHYR_COMPAT["v${BACKEND_VERSION}"]}"
echo "WORKSPACE=${WORKSPACE}  BACKEND_VERSION=${BACKEND_VERSION}  ZEPHYR_VERSION=${ZEPHYR_VERSION}"
APPDIR="${WORKSPACE}/app"

# ── Write minimal west manifest ────────────────────────────────────
mkdir -p "${APPDIR}"
cat >"${APPDIR}/west.yml" <<YAML
manifest:
  remotes:
    - name: zephyrproject-rtos
      url-base: https://github.com/zephyrproject-rtos
  projects:
    - name: zephyr
      remote: zephyrproject-rtos
      revision: ${ZEPHYR_VERSION:?}
      clone-depth: 1
      import:
        name-allowlist:
          - cmsis
  self:
    path: app
YAML

# ── West init & update ─────────────────────────────────────────────
cd "${APPDIR}"
mise x "${BACKEND}:west@${BACKEND_VERSION}" -- west init -l .
WEST_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/vfox-${BACKEND}"
mkdir -p "${WEST_CACHE}"
mise x "${BACKEND}:west@${BACKEND_VERSION}" -- west update --narrow --auto-cache "${WEST_CACHE}"
mise set ZEPHYR_BASE="$WORKSPACE/zephyr"
mise x "${BACKEND}:west@${BACKEND_VERSION}" -- west build -p -b native_sim -s "$WORKSPACE/zephyr/samples/hello_world" -d build

# ── Verify output ──────────────────────────────────────────────────
if [[ -d build && -e build/zephyr/zephyr.exe ]]; then
  pass "Integration test: zephyr.exe built successfully"
else
  fail "Integration test: build/zephyr/zephyr.exe not found"
fi
