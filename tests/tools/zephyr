# Test config: plain Zephyr SDK toolchain with option-based target selection.
# Format: key=value (split on first '='). Lines starting with '#' are ignored.
# Convention: use double quotes inside mise option syntax (not single quotes)
# so the full spec can be safely single-quoted at the shell level.
manifest=zephyr
board=native_sim
sample=zephyr/samples/hello_world
toolchain=toolchain[toolchains='arm-zephyr-eabi']@0.17.4
west=west@1.5.0
toolchain_probe=arm-zephyr-eabi-gcc
west_probe=west
